# Optional. new-api normally forwards the channel key in the Authorization header,
# so this is only needed for direct native API calls without Authorization.
SUNO_API_KEY=

# SunoAPI.org upstream base URL.
SUNO_API_BASE_URL=https://api.sunoapi.org

# Public callback URL sent to SunoAPI.org when callers do not provide callBackUrl.
# If empty, the bridge derives one from X-Forwarded-Proto/Host per request.
# Example: https://suno-bridge.example.com/callbacks/sunoapi
CALLBACK_URL=

# Host port published by Docker Compose. The container listens on 3000.
PORT=3000

# Persistent task metadata directory for local `npm start`.
# Docker Compose overrides this to /data.
DATA_DIR=./data

# Default SunoAPI.org music model used when new-api sends legacy mv values.
DEFAULT_MUSIC_MODEL=V4_5ALL

# Request timeout for upstream calls.
UPSTREAM_TIMEOUT_MS=60000

# Optional JSON map for legacy mv -> SunoAPI.org model conversion.
# MODEL_MAP_JSON={"chirp-v3-5":"V4","chirp-v4":"V4","chirp-v4-5":"V4_5"}
MODEL_MAP_JSON=
